    "@supabase/supabase-js": "^2.106.2",
    "@tailwindcss/postcss": "^4",
    "clsx": "^2.1.1",
    "date-fns": "^4.3.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.6",
    "nodemailer": "^8.0.9",
    "openai": "^6.39.1",
    "playwright": "^1.60.0",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
