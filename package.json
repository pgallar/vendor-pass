{
  "name": "vendor-pass",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "NODE_OPTIONS='--max-old-space-size=400' next build --webpack",
    "build:local": "NEXT_DIST_DIR=.next-build next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "backfill": "tsx scripts/backfill-arkiv.ts",
    "sync:arkiv": "tsx scripts/sync-arkiv-status.ts",
    "send:emails": "tsx scripts/send-expiration-emails.ts",
    "verify:arkiv": "tsx scripts/verify-arkiv.ts",
    "db:migrate:docker": "bash scripts/docker-apply-migrations.sh",
    "smoke:profile": "tsx scripts/smoke-profile-api.ts",
    "smoke:mcp": "tsx scripts/smoke-mcp-isolation.ts",
    "smoke:mcp:ai": "tsx scripts/smoke-mcp-ai-extract.ts",
    "smoke:passport": "tsx scripts/smoke-passport.ts",
